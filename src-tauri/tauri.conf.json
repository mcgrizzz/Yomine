{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yomine",
  "version": "0.5.5",
  "identifier": "com.yomine.app",
  "build": {
    "frontendDist": "ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": "ui"
    },
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "ui"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Yomine",
        "width": 1400,
        "height": 805,
        "minWidth": 1400,
        "minHeight": 805,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
