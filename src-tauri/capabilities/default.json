{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window.",
  "windows": [
    "main",
    "themes"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "dialog:default",
    "opener:default",
    "updater:default",
    "process:default"
  ]
}
